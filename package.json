{
  "name": "blanksy",
  "version": "1.3.0",
  "private": true,
  "description": "Minimal blank publishing service in the spirit of telegra.ph",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node scripts/dev.js",
    "dev:app": "node --watch src/server.js",
    "dev:db": "docker compose up db -d",
    "dev:down": "docker compose down",
    "test": "node --test",
    "db:migrate": "node -e \"require('./src/db/migrations').runMigrations().then(()=>process.exit(0)).catch((error)=>{console.error(error);process.exit(1);})\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:desktop": "playwright test --project=desktop-chrome",
    "test:e2e:mobile": "playwright test --project=mobile-safari",
    "test:all": "node --test && playwright test"
  },
  "dependencies": {
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.16.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
